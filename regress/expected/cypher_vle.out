e
2
(1 row)
-- Optimized right-bound paths-to: anonymous start, selective anonymous end
SELECT * FROM cypher('cypher_vle', $$MATCH ()-[e*1..2 {name: "main edge"}]->(:end) RETURN count(*) $$) AS (e agtype);
e
2
