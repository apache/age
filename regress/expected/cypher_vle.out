-- Optimized anonymous terminal: bound start, unused anonymous end
SELECT * FROM cypher('cypher_vle', $$MATCH (u:begin)-[e*1..2 {name: "main edge"}]->() RETURN count(*) $$) AS (e agtype);
e
2
